# Sync deps: YOLO + Whisper backends + the diagnostics dashboard. Visual tests: `just sync-viz`.
sync:
  uv sync --dev --extra yolo --extra speech --extra diagnostics

# Pi variant: skips torch/ultralytics (inference runs on the AI HAT) and
# exposes the apt-installed picamera2/Hailo bindings to the venv. The venv
# must be built from the SYSTEM interpreter — a uv-managed python cannot see
# apt-installed packages even with system-site-packages.
sync-pi:
  { grep -qs '^home = /usr/bin' .venv/pyvenv.cfg && grep -qsi 'include-system-site-packages = true' .venv/pyvenv.cfg; } || { rm -rf .venv && uv venv --system-site-packages --python /usr/bin/python3; }
  UV_PYTHON=/usr/bin/python3 uv sync --dev --extra speech

# Run the Python test suite.
test:
  uv run pytest

download-models:
    uv run src/robot_friend/scripts/download_models.py

# Fetch Whisper model(s) into data/models (default: small). e.g. `just python download-whisper medium`
download-whisper *models:
    uv run src/robot_friend/scripts/download_whisper.py {{models}}

# Fetch Vosk model(s) into data/models (default: en + de). e.g. `just python download-vosk de`
download-vosk *langs:
    uv run src/robot_friend/scripts/download_vosk.py {{langs}}

# Run the robot-friend CLI entrypoint.
run *args:
  uv run robot-friend {{args}}

# Listen on the microphone, transcribe, and print transcripts + matched keywords.
listen *args:
  uv run robot-friend-speech {{args}}

# Run the dashboard. `--demo-scenario nominal` = fake data, no hardware.
diagnostics *args:
  uv run --extra diagnostics robot-friend-diagnostics {{args}}

# One-time setup for the browser-based visual suite: install viz-test deps + Chromium.
sync-viz:
  uv sync --extra diagnostics --group viz-test
  uv run --extra diagnostics --group viz-test playwright install chromium

# Regenerate the screenshot gallery PNGs for visual review (run `just sync-viz` first).
gallery:
  uv run --extra diagnostics --group viz-test pytest tests/diagnostics/visual/test_gallery.py -m visual

# Run the full visual + E2E suite (Tier 1 render checks + Tier 2 gallery). Run `just sync-viz` first.
test-visual:
  uv run --extra diagnostics --group viz-test pytest -m visual
