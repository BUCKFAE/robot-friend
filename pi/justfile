# All recipes run on your dev machine and talk to the Pi over ssh. `host` is an
# ssh alias from ~/.ssh/config; target another Pi with e.g. `PI_HOST=finch-lab just pi::run`.
host := env("PI_HOST", "finch-lab")
remote_dir := "robot-friend"
mjpeg_port := "8081"
dashboard_port := "8080"

# Not rsynced: the Pi keeps its own .venv, and git history / laptop-only models aren't needed.
rsync_excludes := " \
    --exclude=.git \
    --exclude=.venv \
    --exclude=__pycache__ \
    --exclude=.pytest_cache \
    --exclude=.cache \
    --exclude=.pio \
    --exclude=.idea \
    --exclude=.obsidian \
    --exclude=/data \
"

repo_root := parent_directory(source_directory())

# Env prelude for any remote `uv` invocation: put the user-local uv on PATH and
# pin it to the system Python (the Pi venv is built with --system-site-packages
# off /usr/bin/python3 for the apt Hailo/camera stack). Prepend to an ssh command,
# e.g. ssh {{host}} '{{pi_env}} cd {{remote_dir}} && uv run ...'.
pi_env := 'export PATH="$HOME/.local/bin:$PATH" UV_PYTHON=/usr/bin/python3;'

_default:
    just --list

# Fail fast if the Pi isn't reachable, so upload/setup/run can't half-run against a dead host.
validate-connection:
    #!/usr/bin/env bash
    set -euo pipefail
    echo "Validating ssh connection to {{host}}..."
    if ! ssh -o BatchMode=yes -o ConnectTimeout=5 {{host}} true 2>/dev/null; then
        echo "error: cannot reach '{{host}}' over ssh." >&2
        echo "  - is the Pi powered on and on the network?" >&2
        echo "  - is '{{host}}' an ssh alias in ~/.ssh/config (or set PI_HOST)?" >&2
        echo "  - is your ssh key authorized on the Pi? (BatchMode needs key auth)" >&2
        exit 1
    fi
    echo "ok: '{{host}}' is reachable"

# Sync the repo to the Pi.
upload: validate-connection
  @echo "Uploading to {{host}}:{{remote_dir}}"
  rsync -rvP --delete {{rsync_excludes}} "{{repo_root}}/" "{{host}}:{{remote_dir}}/"

# Provision the Pi (Hailo, PCIe Gen 3, uv + just, Python env) — idempotent, reboot once afterwards.
setup: upload
  @echo "Provisioning the Pi..."
  ssh -t {{host}} '{{remote_dir}}/scripts/setup.sh'

# Verify the AI HAT and camera are detected (run after reboot).
check:
  ssh {{host}} 'lspci | grep -i hailo && ls /dev/hailo0 && hailortcli fw-control identify && rpicam-hello --list-cameras'

# Fetch only the Vosk ASR models: the Pi runs image detection on the Hailo HAT
# (no YOLO/torch) and Vosk — not Whisper — for real-time ASR.
download: upload
  ssh {{host}} '{{pi_env}} cd {{remote_dir}} && uv run --extra audio src/robot_friend/scripts/download_data.py vosk'

# Upload, run person detection on the AI HAT, and open the annotated live view.
run *args: upload
  #!/usr/bin/env bash
  set -euo pipefail
  ssh {{host}} '{{pi_env}} export HAILO_MONITOR=1; pkill -f "[.]venv/bin/robot-friend" 2>/dev/null; cd {{remote_dir}} && just sync && uv run robot-friend --port {{mjpeg_port}} {{args}}' &
  ssh_pid=$!
  trap 'kill $ssh_pid 2>/dev/null' EXIT
  pi_ip=$(ssh -G {{host}} | awk '/^hostname /{print $2}')
  until (exec 3<> "/dev/tcp/$pi_ip/{{mjpeg_port}}") 2>/dev/null; do
    kill -0 $ssh_pid 2>/dev/null || { echo "remote run exited before the stream came up" >&2; exit 1; }
    sleep 1
  done
  just connect

# Upload, serve the NiceGUI dashboard web UI on the Pi, and open it in a browser.
dashboard: upload
  #!/usr/bin/env bash
  set -euo pipefail
  ssh {{host}} '{{pi_env}} export HAILO_MONITOR=1; pkill -f "[.]venv/bin/robot-friend" 2>/dev/null; cd {{remote_dir}} && just sync && uv run robot-friend-dashboard' &
  ssh_pid=$!
  trap 'kill $ssh_pid 2>/dev/null' EXIT
  pi_ip=$(ssh -G {{host}} | awk '/^hostname /{print $2}')
  until (exec 3<> "/dev/tcp/$pi_ip/{{dashboard_port}}") 2>/dev/null; do
    kill -0 $ssh_pid 2>/dev/null || { echo "remote dashboard exited before it came up" >&2; exit 1; }
    sleep 1
  done
  open "http://$pi_ip:{{dashboard_port}}/dashboard/"
  wait $ssh_pid


# Watch the raw Pi camera with no robot-friend code: H.264 TCP stream from the Pi, viewed here.
stream port="8554":
  #!/usr/bin/env bash
  set -euo pipefail
  ssh {{host}} 'rpicam-vid -t 0 -n --inline --listen -o tcp://0.0.0.0:{{port}}' &
  ssh_pid=$!
  trap 'kill $ssh_pid 2>/dev/null; ssh {{host}} "pkill -f rpicam-vid" 2>/dev/null' EXIT
  pi_ip=$(ssh -G {{host}} | awk '/^hostname /{print $2}')
  # rpicam-vid --listen serves a single client, so wait for the listen socket via ss
  # (which never opens it) rather than probing the port ourselves.
  ssh {{host}} 'until ss -ltn 2>/dev/null | grep -q ":{{port}} "; do sleep 0.3; done'
  ffplay -fflags nobuffer -flags low_delay "tcp://$pi_ip:{{port}}"

# View the annotated MJPEG view that `just pi::run` serves from main.py (HTTP, not raw TCP).
connect:
  ffplay -fflags nobuffer -flags low_delay "http://$(ssh -G {{host}} | awk '/^hostname /{print $2}'):{{mjpeg_port}}/"
