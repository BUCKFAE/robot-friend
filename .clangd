# clangd project config — keeps the LSP quiet on a PlatformIO/Arduino tree.
#
# compile_commands.json is generated by scripts/gen_compile_commands.py.
# That file holds the real compile flags per source; this config only
# tweaks how clangd interprets them.

CompileFlags:
  # GCC link-time-optimization control that the clang frontend doesn't
  # know about. AVR builds set it via -flto + this flag; clang just needs
  # to ignore it during parsing.
  Remove:
    - -fno-fat-lto-objects

Diagnostics:
  # Arduino headers chain transitively in ways IncludeCleaner can't
  # follow — it'd otherwise spam warnings about Arduino.h.
  UnusedIncludes: None
  MissingIncludes: None
  # Default tidy checks fire heavily on Arduino-style code. Opt back in
  # later by adding a project-level .clang-tidy file.
  ClangTidy:
    Remove: ['*']
